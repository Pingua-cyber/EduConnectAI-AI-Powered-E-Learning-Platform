<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account - EduConnect AI</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-headline { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(226, 215, 255, 0.5); }
        .bg-mesh-light {
            background-color: #faf4ff;
            background-image: 
                radial-gradient(at 0% 0%, #e0d4ff 0, transparent 50%), 
                radial-gradient(at 50% 0%, #d4e3ff 0, transparent 50%), 
                radial-gradient(at 100% 0%, #ffd4e3 0, transparent 50%);
            background-attachment: fixed;
        }
        .role-card.selected { border-color: #4a40e0; background: white; box-shadow: 0 10px 25px rgba(74, 64, 224, 0.1); }
        .role-card.selected .icon-box { background: #4a40e0; color: white; }
    </style>
</head>
<body class="bg-mesh-light h-screen overflow-hidden flex">
    <!-- Left Side: Beautiful Realistic Classroom Image -->
    <div class="hidden lg:flex lg:w-3/5 relative items-center justify-center overflow-hidden bg-[#0B0914]">
        <img src="/images/realistic_classroom.png" alt="Realistic University Classroom" class="absolute inset-0 w-full h-full object-cover opacity-90 object-center">
        
        <!-- Elegant Overlay Gradient -->
        <div class="absolute inset-0 bg-gradient-to-l from-[#faf4ff] via-transparent to-black/30"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#10062d]/60 via-transparent to-transparent"></div>

        <!-- Float Content -->
        <div class="relative z-10 self-end mb-16 mr-12 ml-auto max-w-lg p-8 rounded-3xl border border-white/20 bg-white/10 backdrop-blur-md shadow-2xl text-right">
            <h2 class="text-3xl font-headline font-extrabold mb-3 text-white leading-tight">Begin Your<br>Journey</h2>
            <p class="text-sm font-medium text-white/80 leading-relaxed">Create an account to access interactive courses, intelligent grading, and personalized AI tutoring.</p>
        </div>
    </div>

    <!-- Right Side: Form (Scroll if necessary on small screens, fixed on desktop) -->
    <div class="w-full lg:w-2/5 h-full overflow-y-auto lg:overflow-hidden flex items-center justify-center p-6 sm:p-10 relative bg-white/40 backdrop-blur-xl z-20">
        <div class="max-w-xl w-full mx-auto flex flex-col justify-center h-full max-h-screen py-4">
        <!-- Logo & Header -->
        <div class="text-center mb-4">
            <h1 class="text-2xl font-headline font-extrabold tracking-tight text-[#1a1438]">Join EduConnect AI</h1>
            <p class="text-[#32294f]/60 font-medium mt-1 text-xs">Choose your path and start learning today</p>
        </div>

        <div class="glass rounded-[2rem] p-5 md:p-8 shadow-2xl shadow-[#4a40e0]/5">
            <% if (error) { %>
                <div class="mb-4 p-3 rounded-xl bg-red-50 border border-red-100 flex items-center gap-2 text-red-600 text-xs font-bold">
                    <span class="material-symbols-outlined text-[16px]">error</span>
                    <%= error %>
                </div>
            <% } %>

            <form action="/auth/register" method="POST" class="space-y-4">
                <!-- Role Selection -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <label class="relative cursor-pointer group">
                        <input type="radio" name="role" value="student" class="peer hidden" checked onchange="updateRoleUI()">
                        <div class="role-card h-full p-3 rounded-2xl border-2 border-transparent bg-white/40 hover:bg-white transition-all peer-checked:border-[#4a40e0] peer-checked:bg-white peer-checked:shadow-md">
                            <div class="flex items-center gap-3 mb-1">
                                <div class="icon-box w-8 h-8 rounded-xl bg-[#e8deff] text-[#4a40e0] flex items-center justify-center transition-colors">
                                    <span class="material-symbols-outlined text-[18px]">person</span>
                                </div>
                                <h3 class="font-headline font-bold text-sm text-[#1a1438]">Student</h3>
                            </div>
                            <p class="text-[10px] text-[#32294f]/50 font-medium leading-tight">Access courses & AI quizzes.</p>
                        </div>
                    </label>

                    <label class="relative cursor-pointer group">
                        <input type="radio" name="role" value="teacher" class="peer hidden" onchange="updateRoleUI()">
                        <div class="role-card h-full p-3 rounded-2xl border-2 border-transparent bg-white/40 hover:bg-white transition-all peer-checked:border-[#4a40e0] peer-checked:bg-white peer-checked:shadow-md">
                            <div class="flex items-center gap-3 mb-1">
                                <div class="icon-box w-8 h-8 rounded-xl bg-[#f5eeff] text-[#702ae1] flex items-center justify-center transition-colors">
                                    <span class="material-symbols-outlined text-[18px]">psychology</span>
                                </div>
                                <h3 class="font-headline font-bold text-sm text-[#1a1438]">Teacher</h3>
                            </div>
                            <p class="text-[10px] text-[#32294f]/50 font-medium leading-tight">Create subjects & AI quizzes.</p>
                        </div>
                    </label>
                </div>

                <!-- Input Fields -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    <div class="space-y-1">
                        <label for="name" class="text-[9px] font-black text-[#5f557f] uppercase tracking-[0.2em] ml-2">Full Name</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[#32294f]/30 group-focus-within:text-[#4a40e0] transition-colors text-[18px]">person</span>
                            <input type="text" id="name" name="name" required
                                   class="w-full bg-white/60 border-2 border-transparent rounded-xl pl-9 pr-3 py-2.5 focus:bg-white focus:border-[#4a40e0]/30 focus:ring-4 focus:ring-[#4a40e0]/5 outline-none transition-all font-semibold text-xs placeholder:text-[#32294f]/30"
                                   placeholder="John Doe">
                        </div>
                    </div>

                    <div class="space-y-1">
                        <label for="email" class="text-[9px] font-black text-[#5f557f] uppercase tracking-[0.2em] ml-2">Email Address</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[#32294f]/30 group-focus-within:text-[#4a40e0] transition-colors text-[18px]">mail</span>
                            <input type="email" id="email" name="email" required
                                   class="w-full bg-white/60 border-2 border-transparent rounded-xl pl-9 pr-3 py-2.5 focus:bg-white focus:border-[#4a40e0]/30 focus:ring-4 focus:ring-[#4a40e0]/5 outline-none transition-all font-semibold text-xs placeholder:text-[#32294f]/30"
                                   placeholder="your@email.com">
                        </div>
                    </div>

                    <div class="space-y-1 md:col-span-2">
                        <label for="password" class="text-[9px] font-black text-[#5f557f] uppercase tracking-[0.2em] ml-2">Secure Password</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-[#32294f]/30 group-focus-within:text-[#4a40e0] transition-colors text-[18px]">lock</span>
                            <input type="password" id="password" name="password" required
                                   class="w-full bg-white/60 border-2 border-transparent rounded-xl pl-9 pr-9 py-2.5 focus:bg-white focus:border-[#4a40e0]/30 focus:ring-4 focus:ring-[#4a40e0]/5 outline-none transition-all font-semibold text-xs placeholder:text-[#32294f]/30"
                                   placeholder="Min. 8 characters">
                            <button type="button" onclick="togglePassword('password', 'eye-icon')" class="absolute right-3 top-1/2 -translate-y-1/2 text-[#32294f]/30 hover:text-[#4a40e0] transition-colors">
                                <span class="material-symbols-outlined text-[16px]" id="eye-icon">visibility</span>
                            </button>
                        </div>
                    </div>
                </div>

                <button type="submit" class="w-full bg-gradient-to-br from-[#4a40e0] to-[#702ae1] text-white font-headline font-bold py-3 rounded-xl shadow-lg shadow-[#4a40e0]/20 hover:scale-[1.01] active:scale-[0.99] transition-all flex items-center justify-center gap-2 mt-2">
                    <span id="btn-text" class="text-sm">Create Student Account</span>
                    <span class="material-symbols-outlined text-[18px]">how_to_reg</span>
                </button>
            </form>

            <div class="mt-5 pt-4 border-t border-[#e2d7ff]/50 text-center">
                <p class="text-xs font-medium text-[#32294f]/60">
                    Already have an account? 
                    <a href="/auth/login" class="text-[#4a40e0] font-bold hover:underline ml-1">Sign in here</a>
                </p>
            </div>
        </div>

        <!-- Footer Info -->
        <p class="mt-4 text-center text-[9px] font-black text-[#32294f]/40 uppercase tracking-[0.2em]">
            &copy; 2026 EduConnect AI Platform
        </p>
        </div>
    </div>

    <script>
        function updateRoleUI() {
            const role = document.querySelector('input[name="role"]:checked').value;
            const btnText = document.getElementById('btn-text');
            btnText.innerText = role === 'teacher' ? 'Create Teacher Account' : 'Create Student Account';
        }
        
        function togglePassword(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerText = 'visibility_off';
            } else {
                input.type = 'password';
                icon.innerText = 'visibility';
            }
        }
        
        // Initialize
        updateRoleUI();
    </script>
</body>
</html>
