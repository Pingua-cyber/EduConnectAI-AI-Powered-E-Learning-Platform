<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= course.title %> - EduConnect AI</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #faf4ff; }
        h1, h2, h3, h4 { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="text-[#32294f] pb-12">
    <%- include('../partials/student-sidebar') %>

    <!-- Top Navigation -->
    <nav class="sticky top-0 z-50 bg-[#faf4ff]/80 backdrop-blur-xl border-b border-[#e2d7ff]/50">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <a href="/student/subject/<%= course.subject_id %>" class="w-10 h-10 rounded-xl bg-white border border-[#e2d7ff] flex items-center justify-center text-[#4a40e0] hover:bg-[#f5eeff] transition-colors shadow-sm">
                    <span class="material-symbols-outlined">arrow_back</span>
                </a>
            </div>
            <div class="flex items-center gap-4">
                <div class="hidden md:flex flex-col items-end mr-2">
                    <span class="font-bold text-sm leading-tight"><%= user.name %></span>
                    <span class="text-xs text-[#32294f]/60 font-medium">Student</span>
                </div>
                <div class="relative">
                    <button onclick="toggleProfileDropdown()" class="w-10 h-10 rounded-full bg-[#e8deff] text-[#4a40e0] flex items-center justify-center font-bold border-2 border-white shadow-sm overflow-hidden hover:ring-2 hover:ring-[#4a40e0] transition-all" id="profileBtn">
                        <% if (user.profile_image) { %>
                            <img src="<%= user.profile_image %>" class="w-full h-full object-cover">
                        <% } else { %>
                            <%= user.name.charAt(0).toUpperCase() %>
                        <% } %>
                    </button>
                    <!-- Profile Dropdown -->
                    <div id="profileDropdown" class="absolute right-0 mt-2 w-48 bg-white rounded-2xl shadow-xl border border-[#e2d7ff] py-2 hidden z-[60]">
                        <div class="px-4 py-2 border-b border-[#e2d7ff] mb-1">
                            <p class="text-xs text-[#32294f]/50 font-bold uppercase tracking-wider">Account Settings</p>
                        </div>
                        <a href="/student/profile" class="flex items-center gap-3 px-4 py-3 text-sm font-semibold text-[#32294f] hover:bg-[#f5eeff] transition-colors">
                            <span class="material-symbols-outlined text-[20px]">account_circle</span> My Profile
                        </a>
                        <a href="/auth/logout" class="flex items-center gap-3 px-4 py-3 text-sm font-semibold text-red-500 hover:bg-red-50 transition-colors">
                            <span class="material-symbols-outlined text-[20px]">logout</span> Logout
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-6 py-8">
        
        <header class="mb-8">
            <div class="bg-gradient-to-br from-[#4a40e0] to-[#702ae1] rounded-[2.5rem] p-8 md:p-12 text-white shadow-xl shadow-[#4a40e0]/20 relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-20">
                    <span class="material-symbols-outlined text-[120px]" style="font-variation-settings: 'FILL' 1;">book_4</span>
                </div>
                <div class="relative z-10">
                    <h1 class="text-3xl md:text-5xl font-extrabold tracking-tight mb-4"><%= course.title %></h1>
                    <p class="text-white/80 font-medium max-w-2xl text-lg leading-relaxed"><%= course.description %></p>
                </div>
            </div>
        </header>

        <!-- Custom Tabs -->
        <div class="flex space-x-2 border-b border-[#e2d7ff] mb-10 overflow-x-auto no-scrollbar">
            <button onclick="switchTab('materials')" id="tab-btn-materials" class="flex items-center gap-2 px-8 py-5 font-bold border-b-2 border-[#4a40e0] text-[#4a40e0] transition-colors whitespace-nowrap">
                <span class="material-symbols-outlined">folder</span> Learning Materials
            </button>
            <button onclick="switchTab('quizzes')" id="tab-btn-quizzes" class="flex items-center gap-2 px-8 py-5 font-bold border-b-2 border-transparent text-[#32294f]/60 hover:text-[#4a40e0] transition-colors whitespace-nowrap">
                <span class="material-symbols-outlined">quiz</span> Assessments
            </button>
        </div>

        <!-- Materials Tab Content -->
        <div id="tab-content-materials" class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <% if (materials && materials.length > 0) { %>
                <% materials.forEach(m => { %>
                    <div class="bg-white rounded-3xl p-6 border border-[#e2d7ff] shadow-sm flex items-center justify-between group hover:border-[#9795ff] transition-all">
                        <div class="flex items-center gap-5 min-w-0">
                            <div class="w-14 h-14 flex-shrink-0 rounded-2xl <%= m.type === 'pdf' ? 'bg-[#fce8e6] text-[#c5221f]' : 'bg-[#e8deff] text-[#4a40e0]' %> flex items-center justify-center group-hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined text-2xl" style="font-variation-settings: 'FILL' 1;"><%= m.type === 'pdf' ? 'picture_as_pdf' : 'play_circle' %></span>
                            </div>
                            <div class="min-w-0">
                                <h4 class="font-extrabold text-[#32294f] truncate text-lg"><%= m.title %></h4>
                                <p class="text-[10px] uppercase font-bold text-[#32294f]/50 tracking-wider flex items-center gap-1">
                                    <%= m.type %> &bull; <span class="text-[#4a40e0]">Study Guide</span>
                                </p>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 ml-4">
                            <% if(m.type === 'pdf') { %>
                                <a href="<%= m.path %>" target="_blank" class="px-5 py-2.5 rounded-xl bg-[#faf4ff] text-[#4a40e0] font-bold text-sm hover:bg-[#4a40e0] hover:text-white transition-all border border-[#e2d7ff]">
                                    Open
                                </a>
                            <% } else { %>
                                <a href="<%= m.video_url || m.path %>" target="_blank" class="px-5 py-2.5 rounded-xl bg-[#4a40e0] text-white font-bold text-sm hover:bg-[#3d30d4] transition-all border border-transparent">
                                    Watch
                                </a>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-span-full py-20 text-center bg-white rounded-[3rem] border-2 border-dashed border-[#e2d7ff]">
                    <div class="w-20 h-20 bg-[#f5eeff] text-[#4a40e0] rounded-full flex items-center justify-center mx-auto mb-6">
                        <span class="material-symbols-outlined text-4xl">inventory_2</span>
                    </div>
                    <h3 class="text-xl font-bold mb-2">No Materials Available</h3>
                    <p class="text-[#32294f]/60 max-w-sm mx-auto">Your teacher hasn't uploaded any study materials for this course yet.</p>
                </div>
            <% } %>
        </div>

        <!-- Quizzes Tab Content -->
        <div id="tab-content-quizzes" class="hidden grid grid-cols-1 md:grid-cols-2 gap-6">
            <% if (quizzes && quizzes.length > 0) { %>
                <% quizzes.forEach(q => { %>
                    <div class="bg-white rounded-3xl p-6 border border-[#e2d7ff] shadow-sm flex items-center justify-between group hover:border-[#9795ff] transition-all">
                        <div class="flex items-center gap-5 min-w-0">
                            <div class="w-14 h-14 flex-shrink-0 rounded-2xl bg-[#e6f4ea] text-[#137333] flex items-center justify-center group-hover:scale-110 transition-transform">
                                <span class="material-symbols-outlined text-2xl" style="font-variation-settings: 'FILL' 1;">assignment</span>
                            </div>
                            <div class="min-w-0">
                                <h4 class="font-extrabold text-[#32294f] truncate text-lg"><%= q.title %></h4>
                                <% if (q.student_score !== null) { %>
                                    <div class="flex items-center gap-2 mt-1">
                                        <span class="text-xs font-bold px-2 py-0.5 rounded-md <%= q.student_score >= 50 ? 'bg-[#e6f4ea] text-[#137333]' : 'bg-[#fce8e6] text-[#c5221f]' %>">
                                            Score: <%= q.student_score %>%
                                        </span>
                                        <span class="text-[10px] text-[#32294f]/40 font-bold uppercase tracking-widest">Completed</span>
                                    </div>
                                <% } else { %>
                                    <span class="text-[10px] text-[#4a40e0] font-bold uppercase tracking-widest mt-1 block">Not Started</span>
                                <% } %>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 ml-4">
                            <% if (q.student_score !== null) { %>
                                <button class="px-5 py-2.5 rounded-xl bg-[#f8f9fa] text-gray-400 font-bold text-sm border border-gray-100 cursor-not-allowed" disabled>
                                    Done
                                </button>
                            <% } else { %>
                                <a href="/student/course/<%= course.id %>/quiz/<%= q.id %>" class="px-5 py-2.5 rounded-xl bg-gradient-to-br from-[#4a40e0] to-[#702ae1] text-white font-bold text-sm hover:shadow-lg hover:shadow-[#4a40e0]/20 transition-all">
                                    Take Quiz
                                </a>
                            <% } %>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-span-full py-20 text-center bg-white rounded-[3rem] border-2 border-dashed border-[#e2d7ff]">
                    <div class="w-20 h-20 bg-[#f5eeff] text-[#4a40e0] rounded-full flex items-center justify-center mx-auto mb-6">
                        <span class="material-symbols-outlined text-4xl">quiz</span>
                    </div>
                    <h3 class="text-xl font-bold mb-2">No Assessments Yet</h3>
                    <p class="text-[#32294f]/60 max-w-sm mx-auto">Check back later for newly published quizzes by your instructor.</p>
                </div>
            <% } %>
        </div>

    </main>

    <!-- Bottom Navigation -->
    

    <script>
        function toggleProfileDropdown() {
            const d = document.getElementById('profileDropdown');
            d.classList.toggle('hidden');
        }

        function switchTab(tab) {
            document.getElementById('tab-content-materials').classList.add('hidden');
            document.getElementById('tab-content-quizzes').classList.add('hidden');
            document.getElementById(`tab-content-${tab}`).classList.remove('hidden');

            const btnM = document.getElementById('tab-btn-materials');
            const btnQ = document.getElementById('tab-btn-quizzes');

            if(tab === 'materials') {
                btnM.classList.add('border-[#4a40e0]', 'text-[#4a40e0]');
                btnM.classList.remove('border-transparent', 'text-[#32294f]/60');
                btnQ.classList.remove('border-[#4a40e0]', 'text-[#4a40e0]');
                btnQ.classList.add('border-transparent', 'text-[#32294f]/60');
            } else {
                btnQ.classList.add('border-[#4a40e0]', 'text-[#4a40e0]');
                btnQ.classList.remove('border-transparent', 'text-[#32294f]/60');
                btnM.classList.remove('border-[#4a40e0]', 'text-[#4a40e0]');
                btnM.classList.add('border-transparent', 'text-[#32294f]/60');
            }
        }

        // Close dropdown when clicking outside
        window.addEventListener('click', (e) => {
            const btn = document.getElementById('profileBtn');
            const d = document.getElementById('profileDropdown');
            if (btn && !btn.contains(e.target) && d && !d.contains(e.target)) {
                d.classList.add('hidden');
            }
        });
    </script>
</body>
</html>
