<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= subject.name %> - EduConnect AI</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #faf4ff; }
        h1, h2, h3, h4 { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="text-[#32294f] pb-12">
    <%- include('../partials/student-sidebar') %>

    <!-- Top Navigation -->
    <nav class="sticky top-0 z-50 bg-[#faf4ff]/80 backdrop-blur-xl border-b border-[#e2d7ff]/50">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <a href="/student/dashboard" class="w-10 h-10 rounded-xl bg-white border border-[#e2d7ff] flex items-center justify-center text-[#4a40e0] hover:bg-[#f5eeff] transition-colors shadow-sm">
                    <span class="material-symbols-outlined">arrow_back</span>
                </a>
            </div>
            <div class="flex items-center gap-4">
                <div class="hidden md:flex flex-col items-end mr-2">
                    <span class="font-bold text-sm leading-tight"><%= user.name %></span>
                    <span class="text-xs text-[#32294f]/60 font-medium">Student</span>
                </div>
                <div class="relative">
                    <button onclick="toggleProfileDropdown()" class="w-10 h-10 rounded-full bg-[#e8deff] text-[#4a40e0] flex items-center justify-center font-bold border-2 border-white shadow-sm overflow-hidden hover:ring-2 hover:ring-[#4a40e0] transition-all" id="profileBtn">
                        <% if (user.profile_image) { %>
                            <img src="<%= user.profile_image %>" class="w-full h-full object-cover">
                        <% } else { %>
                            <%= user.name.charAt(0).toUpperCase() %>
                        <% } %>
                    </button>
                    <!-- Profile Dropdown -->
                    <div id="profileDropdown" class="absolute right-0 mt-2 w-48 bg-white rounded-2xl shadow-xl border border-[#e2d7ff] py-2 hidden z-[60]">
                        <div class="px-4 py-2 border-b border-[#e2d7ff] mb-1">
                            <p class="text-xs text-[#32294f]/50 font-bold uppercase tracking-wider">Account Settings</p>
                        </div>
                        <a href="/student/profile" class="flex items-center gap-3 px-4 py-3 text-sm font-semibold text-[#32294f] hover:bg-[#f5eeff] transition-colors">
                            <span class="material-symbols-outlined text-[20px]">account_circle</span> My Profile
                        </a>
                        <a href="/auth/logout" class="flex items-center gap-3 px-4 py-3 text-sm font-semibold text-red-500 hover:bg-red-50 transition-colors">
                            <span class="material-symbols-outlined text-[20px]">logout</span> Logout
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-6 py-8">
        
        <header class="mb-10">
            <div class="inline-block px-4 py-1.5 bg-[#e8deff] text-[#4a40e0] text-xs font-bold rounded-full mb-4 uppercase tracking-widest">
                Subject Hub
            </div>
            <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight mb-2"><%= subject.name %></h1>
            <p class="text-[#32294f]/70 font-medium text-lg italic">Taught by <%= subject.teacher_name %></p>
        </header>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% if (courses && courses.length > 0) { %>
                <% courses.forEach(course => { %>
                    <div class="bg-white rounded-[2.5rem] p-8 border border-[#e2d7ff] shadow-sm hover:shadow-xl hover:border-[#9795ff] transition-all group relative overflow-hidden">
                        <!-- Background Pattern -->
                        <div class="absolute -right-4 -top-4 w-24 h-24 bg-[#f5eeff] rounded-full opacity-50 group-hover:scale-150 transition-transform duration-500"></div>
                        
                        <div class="relative z-10">
                            <div class="flex justify-between items-start mb-6">
                                <div class="w-14 h-14 rounded-2xl bg-[#f5eeff] text-[#4a40e0] flex items-center justify-center group-hover:scale-110 transition-transform">
                                    <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">laptop_chromebook</span>
                                </div>
                                <a href="/student/course/<%= course.id %>/delete" 
                                   class="w-10 h-10 flex items-center justify-center rounded-xl bg-red-50 text-red-500 hover:bg-red-500 hover:text-white transition-all shadow-sm"
                                   onclick="return confirm('Are you sure you want to remove this course from your view?')">
                                    <span class="material-symbols-outlined text-[20px]">delete</span>
                                </a>
                            </div>

                            <h3 class="font-extrabold text-xl mb-3 line-clamp-1 group-hover:text-[#4a40e0] transition-colors"><%= course.title %></h3>
                            <p class="text-sm text-[#32294f]/60 mb-8 line-clamp-3 min-h-[4.5rem] leading-relaxed">
                                <%= course.description || 'Access all learning resources, quizzes, and materials for this course module.' %>
                            </p>

                            <a href="/student/course/<%= course.id %>" class="w-full py-4 rounded-2xl bg-[#faf4ff] text-[#4a40e0] font-bold text-center block hover:bg-[#4a40e0] hover:text-white transition-all border border-[#e2d7ff] shadow-sm">
                                Access Material Hub
                            </a>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-span-full py-20 text-center bg-white rounded-[3rem] border-2 border-dashed border-[#e2d7ff]">
                    <div class="w-20 h-20 bg-[#f5eeff] text-[#4a40e0] rounded-full flex items-center justify-center mx-auto mb-6">
                        <span class="material-symbols-outlined text-4xl">folder_open</span>
                    </div>
                    <h2 class="text-2xl font-bold mb-2">No Courses Found</h2>
                    <p class="text-[#32294f]/60 max-w-sm mx-auto italic">There are no active courses under this subject at the moment.</p>
                </div>
            <% } %>
        </div>
    </main>

    <!-- Bottom Navigation -->
    

    <script>
        function toggleProfileDropdown() {
            const d = document.getElementById('profileDropdown');
            d.classList.toggle('hidden');
        }

        // Close dropdown when clicking outside
        window.addEventListener('click', (e) => {
            const btn = document.getElementById('profileBtn');
            const d = document.getElementById('profileDropdown');
            if (btn && !btn.contains(e.target) && d && !d.contains(e.target)) {
                d.classList.add('hidden');
            }
        });
    </script>
</body>
</html>
