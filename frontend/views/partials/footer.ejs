<!-- Bootstrap 5 JS Bundle with Popper -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<!-- Handle AI Requests locally -->
<script>
    async function askStudyBuddy(term) {
        // Find result div
        const resultDiv = document.getElementById('aiResult');
        if (resultDiv) resultDiv.innerHTML = '<div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>';
        
        try {
            const response = await fetch('/ai/student/study-buddy', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ term })
            });
            const text = await response.text();
            if (!text.startsWith("ERROR:")) {
                resultDiv.innerHTML = `<div class="alert alert-info mt-3"><i class="fa-solid fa-robot me-2"></i> ${text}</div>`;
            } else {
                resultDiv.innerHTML = `<div class="alert alert-danger mt-3">${text}</div>`;
            }
        } catch (e) {
            resultDiv.innerHTML = `<div class="alert alert-danger mt-3">An error occurred.</div>`;
        }
    }

    async function generateMCQs(topic) {
        const resultDiv = document.getElementById('aiResult');
        if (resultDiv) resultDiv.innerHTML = '<div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>';
        
        try {
            const response = await fetch('/ai/teacher/generate-mcq', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ topic })
            });
            const data = await response.json();
            if (data.success) {
                let html = '<div class="mt-3">';
                data.questions.forEach((q, index) => {
                    html += `<div class="card card-custom mb-3"><div class="card-body">
                                <h6>Q${index+1}: ${q.question}</h6>
                                <ul class="list-group list-group-flush text-start">`;
                    q.options.forEach(opt => {
                        html += `<li class="list-group-item ${opt === q.answer ? 'list-group-item-success' : ''}">${opt}</li>`;
                    });
                    html += `</ul></div></div>`;
                });
                html += '</div>';
                resultDiv.innerHTML = html;
            } else {
                resultDiv.innerHTML = `<div class="alert alert-danger mt-3">Error: ${data.error}</div>`;
            }
        } catch (e) {
            resultDiv.innerHTML = `<div class="alert alert-danger mt-3">An error occurred.</div>`;
        }
    }
</script>
</body>
</html>
