<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password - EduConnect AI</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-headline { font-family: 'Plus Jakarta Sans', sans-serif; }
        .glass { background: rgba(255, 255, 255, 0.7); backdrop-filter: blur(20px); border: 1px solid rgba(226, 215, 255, 0.5); }
        .bg-mesh-light {
            background-color: #faf4ff;
            background-image: 
                radial-gradient(at 0% 0%, #e0d4ff 0, transparent 50%), 
                radial-gradient(at 50% 0%, #d4e3ff 0, transparent 50%), 
                radial-gradient(at 100% 0%, #ffd4e3 0, transparent 50%);
            background-attachment: fixed;
        }
    </style>
</head>
<body class="bg-mesh-light h-screen overflow-hidden flex">
    <!-- Left Side: Beautiful Realistic Classroom Image -->
    <div class="hidden lg:flex lg:w-3/5 relative items-center justify-center overflow-hidden bg-[#0B0914]">
        <img src="/images/realistic_classroom.png" alt="Realistic University Classroom" class="absolute inset-0 w-full h-full object-cover opacity-90 object-center">
        
        <!-- Elegant Overlay Gradient -->
        <div class="absolute inset-0 bg-gradient-to-l from-[#faf4ff] via-transparent to-black/30"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-[#10062d]/60 via-transparent to-transparent"></div>

        <!-- Float Content -->
        <div class="relative z-10 self-end mb-16 mr-12 ml-auto max-w-lg p-8 rounded-3xl border border-white/20 bg-white/10 backdrop-blur-md shadow-2xl text-right">
            <h2 class="text-3xl font-headline font-extrabold mb-3 text-white leading-tight">Secure Your<br>Account</h2>
            <p class="text-sm font-medium text-white/80 leading-relaxed">Update your password to quickly get back to your personalized AI learning experience.</p>
        </div>
    </div>

    <!-- Right Side: Form (No Scroll) -->
    <div class="w-full lg:w-2/5 h-full flex flex-col justify-center p-6 sm:p-10 relative bg-white/40 backdrop-blur-xl z-20">
        <div class="max-w-md w-full mx-auto flex flex-col justify-center">
            <!-- Header -->
            <div class="text-left mb-8">
                <div class="inline-flex items-center justify-center w-12 h-12 rounded-2xl bg-gradient-to-br from-[#4a40e0] to-[#702ae1] text-white shadow-xl shadow-[#4a40e0]/30 mb-5">
                    <span class="material-symbols-outlined text-2xl">lock_reset</span>
                </div>
                <h1 class="text-3xl sm:text-4xl font-headline font-extrabold tracking-tight text-[#1a1438]">Reset Password</h1>
                <p class="text-[#32294f]/60 font-medium mt-2 text-sm sm:text-base">Enter your email and create a new password</p>
            </div>

            <!-- Card -->
            <div class="bg-white/80 rounded-[2rem] p-6 sm:p-8 shadow-2xl shadow-[#4a40e0]/5 border border-[#e2d7ff]/50">
                <% if (error) { %>
                    <div class="mb-5 p-4 rounded-xl bg-red-50 border border-red-100 flex items-center gap-3 text-red-600 text-xs sm:text-sm font-bold">
                        <span class="material-symbols-outlined">error</span>
                        <%= error %>
                    </div>
                <% } %>
                
                <% if (success) { %>
                    <div class="mb-5 p-4 rounded-xl bg-green-50 border border-green-100 flex items-center gap-3 text-green-600 text-xs sm:text-sm font-bold">
                        <span class="material-symbols-outlined">check_circle</span>
                        <%= success %>
                    </div>
                <% } %>

                <form action="/auth/forgot-password" method="POST" class="space-y-5" onsubmit="return validatePasswords()">
                    <div class="space-y-2">
                        <label for="email" class="text-[10px] sm:text-xs font-black text-[#5f557f] uppercase tracking-[0.2em] ml-2">Account Email</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#32294f]/30 group-focus-within:text-[#4a40e0] transition-colors text-[20px]">mail</span>
                            <input type="email" id="email" name="email" required
                                   class="w-full bg-[#f5eeff] border-2 border-transparent rounded-xl pl-11 pr-4 py-3 focus:bg-white focus:border-[#4a40e0] focus:ring-4 focus:ring-[#4a40e0]/10 outline-none transition-all font-semibold text-sm placeholder:text-[#32294f]/30"
                                   placeholder="your@email.com">
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label for="name" class="text-[10px] sm:text-xs font-black text-[#5f557f] uppercase tracking-[0.2em] ml-2">Full Name (Verification)</label>
                        <div class="relative group">
                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#32294f]/30 group-focus-within:text-[#4a40e0] transition-colors text-[20px]">person</span>
                            <input type="text" id="name" name="name" required
                                   class="w-full bg-[#f5eeff] border-2 border-transparent rounded-xl pl-11 pr-4 py-3 focus:bg-white focus:border-[#4a40e0] focus:ring-4 focus:ring-[#4a40e0]/10 outline-none transition-all font-semibold text-sm placeholder:text-[#32294f]/30"
                                   placeholder="Your registered name">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div class="space-y-2">
                            <label for="new_password" class="text-[10px] sm:text-xs font-black text-[#5f557f] uppercase tracking-[0.2em] ml-2">New Password</label>
                            <div class="relative group">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#32294f]/30 group-focus-within:text-[#4a40e0] transition-colors text-[20px]">lock</span>
                                <input type="password" id="new_password" name="new_password" required minlength="8"
                                       class="w-full bg-[#f5eeff] border-2 border-transparent rounded-xl pl-11 pr-4 py-3 focus:bg-white focus:border-[#4a40e0] focus:ring-4 focus:ring-[#4a40e0]/10 outline-none transition-all font-semibold text-sm placeholder:text-[#32294f]/30"
                                       placeholder="Min. 8 chars">
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label for="confirm_password" class="text-[10px] sm:text-xs font-black text-[#5f557f] uppercase tracking-[0.2em] ml-2">Confirm Password</label>
                            <div class="relative group">
                                <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#32294f]/30 group-focus-within:text-[#4a40e0] transition-colors text-[20px]">lock</span>
                                <input type="password" id="confirm_password" name="confirm_password" required minlength="8"
                                       class="w-full bg-[#f5eeff] border-2 border-transparent rounded-xl pl-11 pr-4 py-3 focus:bg-white focus:border-[#4a40e0] focus:ring-4 focus:ring-[#4a40e0]/10 outline-none transition-all font-semibold text-sm placeholder:text-[#32294f]/30"
                                       placeholder="Retype password">
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="w-full bg-gradient-to-br from-[#4a40e0] to-[#702ae1] text-white font-headline font-extrabold py-4 rounded-xl shadow-xl shadow-[#4a40e0]/30 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-2 mt-4">
                        Reset Password
                        <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                    </button>
                </form>

                <div class="mt-8 pt-6 border-t border-[#e2d7ff]/50 text-center">
                    <p class="text-sm font-medium text-[#32294f]/60">
                        Remember your password? 
                        <a href="/auth/login" class="text-[#4a40e0] font-bold hover:underline ml-1">Back to Login</a>
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script>
        function validatePasswords() {
            const newPass = document.getElementById('new_password').value;
            const confPass = document.getElementById('confirm_password').value;
            if (newPass !== confPass) {
                alert("Passwords do not match! Please try again.");
                return false;
            }
            return true;
        }
    </script>
</body>
</html>
