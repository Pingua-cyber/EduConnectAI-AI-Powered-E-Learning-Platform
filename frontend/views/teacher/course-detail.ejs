<!DOCTYPE html>
<html lang="en" class="light">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= course.title %> - Course Details</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #faf4ff; }
        h1, h2, h3, h4 { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="text-[#32294f] pb-12">
    <%- include('../partials/teacher-sidebar') %>

    <!-- Top Navigation -->
    <nav class="sticky top-0 z-50 bg-[#faf4ff]/80 backdrop-blur-xl border-b border-[#e2d7ff]/50">
        <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <a href="/teacher/dashboard" class="w-10 h-10 rounded-xl bg-white border border-[#e2d7ff] flex items-center justify-center text-[#4a40e0] hover:bg-[#f5eeff] transition-colors shadow-sm">
                    <span class="material-symbols-outlined">arrow_back</span>
                </a>
            </div>
            <div class="flex items-center gap-4">
                <div class="hidden md:flex flex-col items-end mr-2">
                    <span class="font-bold text-sm leading-tight"><%= user.name %></span>
                    <span class="text-xs text-[#32294f]/60 font-medium capitalize"><%= user.role %></span>
                </div>
                <div class="relative">
                    <button onclick="toggleProfileDropdown()" class="w-10 h-10 rounded-full bg-[#e8deff] text-[#4a40e0] flex items-center justify-center font-bold border-2 border-white shadow-sm overflow-hidden hover:ring-2 hover:ring-[#4a40e0] transition-all" id="profileBtn">
                        <% if (user.profile_image) { %>
                            <img src="<%= user.profile_image %>" class="w-full h-full object-cover">
                        <% } else { %>
                            <%= user.name.charAt(0).toUpperCase() %>
                        <% } %>
                    </button>
                    <!-- Profile Dropdown -->
                    <div id="profileDropdown" class="absolute right-0 mt-2 w-48 bg-white rounded-2xl shadow-xl border border-[#e2d7ff] py-2 hidden z-[60]">
                        <div class="px-4 py-2 border-b border-[#e2d7ff] mb-1">
                            <p class="text-xs text-[#32294f]/50 font-bold uppercase tracking-wider">Profile Management</p>
                        </div>
                        <a href="/teacher/profile" class="flex items-center gap-3 px-4 py-3 text-sm font-semibold text-[#32294f] hover:bg-[#f5eeff] transition-colors">
                            <span class="material-symbols-outlined text-[20px]">account_circle</span> Profile
                        </a>
                        <a href="/auth/logout" class="flex items-center gap-3 px-4 py-3 text-sm font-semibold text-red-500 hover:bg-red-50 transition-colors">
                            <span class="material-symbols-outlined text-[20px]">logout</span> Logout
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-6 py-8">
        
        <header class="mb-8">
            <div class="bg-gradient-to-br from-[#4a40e0] to-[#702ae1] rounded-3xl p-8 text-white shadow-xl shadow-[#4a40e0]/20 relative overflow-hidden">
                <div class="absolute top-0 right-0 p-4 opacity-20">
                    <span class="material-symbols-outlined text-8xl" style="font-variation-settings: 'FILL' 1;">book_4</span>
                </div>
                <div class="relative z-10 flex justify-between items-start gap-4">
                    <div>
                        <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-2"><%= course.title %></h1>
                        <p class="text-white/80 font-medium max-w-2xl"><%= course.description %></p>
                    </div>
                </div>
            </div>
        </header>

        <!-- Custom Tabs -->
        <div class="flex space-x-2 border-b border-[#e2d7ff] mb-8 overflow-x-auto no-scrollbar">
            <button onclick="switchTab('materials')" id="tab-btn-materials" class="flex items-center gap-2 px-6 py-4 font-bold border-b-2 border-[#4a40e0] text-[#4a40e0] transition-colors whitespace-nowrap">
                <span class="material-symbols-outlined">folder</span> Course Materials
            </button>
            <button onclick="switchTab('quizzes')" id="tab-btn-quizzes" class="flex items-center gap-2 px-6 py-4 font-bold border-b-2 border-transparent text-[#32294f]/60 hover:text-[#4a40e0] transition-colors whitespace-nowrap">
                <span class="material-symbols-outlined">psychology</span> AI Quizzes
            </button>
        </div>

        <!-- Materials Tab Content -->
        <div id="tab-content-materials" class="space-y-6">
            <div class="flex justify-between items-center">
                <h2 class="text-xl font-bold">Uploaded Materials</h2>
                <button onclick="openUploadModal()" class="flex items-center gap-2 bg-[#4a40e0] text-white px-4 py-2 rounded-xl font-bold hover:bg-[#3d30d4] transition-colors shadow-sm text-sm">
                    <span class="material-symbols-outlined text-[18px]">upload_file</span> Upload Material
                </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <% if (materials && materials.length > 0) { %>
                    <% materials.forEach(m => { %>
                        <div class="bg-white rounded-2xl p-5 border border-[#e2d7ff] shadow-sm flex items-center justify-between group hover:border-[#9795ff] transition-colors">
                            <div class="flex items-center gap-4 min-w-0">
                                <div class="w-12 h-12 flex-shrink-0 rounded-xl <%= m.type === 'pdf' ? 'bg-[#fce8e6] text-[#c5221f]' : 'bg-[#e8deff] text-[#4a40e0]' %> flex items-center justify-center">
                                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;"><%= m.type === 'pdf' ? 'picture_as_pdf' : 'play_circle' %></span>
                                </div>
                                <div class="min-w-0">
                                    <h4 class="font-bold text-[#32294f] truncate"><%= m.title %></h4>
                                    <p class="text-[10px] uppercase font-bold text-[#32294f]/50 tracking-wider"><%= m.type %></p>
                                </div>
                            </div>
                            <div class="flex items-center gap-2 flex-shrink-0 ml-4">
                                <a href="<%= m.type === 'pdf' ? m.path : (m.video_url || m.path) %>" target="_blank" class="w-8 h-8 rounded-lg bg-[#f5eeff] text-[#4a40e0] flex items-center justify-center hover:bg-[#e8deff] transition-colors" title="View">
                                    <span class="material-symbols-outlined text-[18px]">visibility</span>
                                </a>
                                <button onclick="editMaterial('<%= m.id %>', '<%= m.title %>')" class="w-8 h-8 rounded-lg bg-[#f5eeff] text-[#32294f]/60 flex items-center justify-center hover:text-[#4a40e0] transition-colors" title="Edit">
                                    <span class="material-symbols-outlined text-[18px]">edit</span>
                                </button>
                                <button onclick="deleteMaterial('<%= m.id %>', '<%= course.id %>')" class="w-8 h-8 rounded-lg bg-[#fce8e6] text-[#c5221f]/70 flex items-center justify-center hover:text-[#c5221f] transition-colors" title="Delete">
                                    <span class="material-symbols-outlined text-[18px]">delete</span>
                                </button>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-span-1 md:col-span-2 bg-white rounded-3xl p-10 text-center border border-[#e2d7ff] border-dashed">
                        <div class="w-16 h-16 bg-[#f5eeff] text-[#4a40e0] rounded-full flex items-center justify-center mx-auto mb-4">
                            <span class="material-symbols-outlined text-3xl">topic</span>
                        </div>
                        <h3 class="font-bold text-lg mb-2">No Materials Uploaded</h3>
                        <p class="text-[#32294f]/60 mb-6">Start building your course by adding PDFs or Video links.</p>
                        <button onclick="openUploadModal()" class="inline-flex items-center gap-2 bg-[#4a40e0] text-white px-6 py-3 rounded-xl font-bold hover:bg-[#3d30d4] transition-colors">
                            Upload Now
                        </button>
                    </div>
                <% } %>
            </div>
        </div>

        <!-- Quizzes Tab Content -->
        <div id="tab-content-quizzes" class="hidden space-y-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
                <!-- AI Generator -->
                <div class="bg-white rounded-3xl p-8 border border-[#e2d7ff] shadow-sm relative overflow-hidden">
                    <div class="absolute top-0 right-0 p-6 opacity-5 text-[#4a40e0] pointer-events-none">
                        <span class="material-symbols-outlined text-8xl" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                    </div>
                    <div class="relative z-10">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-[#4a40e0] to-[#702ae1] text-white flex items-center justify-center shadow-lg">
                                <span class="material-symbols-outlined">smart_toy</span>
                            </div>
                            <h2 class="text-xl font-bold">AI Quiz Generator</h2>
                        </div>
                        <p class="text-sm text-[#32294f]/60 mb-6">Enter a topic and let Gemini AI magically generate high-quality multiple-choice questions.</p>
                        
                        <div class="space-y-4 mb-6">
                            <div>
                                <label class="block text-xs font-bold uppercase tracking-wider text-[#32294f]/60 mb-2">Topic</label>
                                <input type="text" id="aiTopic" class="w-full bg-[#f5eeff] border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-[#4a40e0] outline-none text-sm" placeholder="e.g. JavaScript Closures">
                            </div>
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                <div>
                                    <label class="block text-xs font-bold uppercase tracking-wider text-[#32294f]/60 mb-2">Quiz Title</label>
                                    <input type="text" id="quizTitle" class="w-full bg-[#f5eeff] border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-[#4a40e0] outline-none text-sm" placeholder="e.g. Midterm Practice Quiz">
                                </div>
                                <div>
                                    <label class="block text-xs font-bold uppercase tracking-wider text-[#32294f]/60 mb-2">Question Count (Max 50)</label>
                                    <input type="number" id="aiCount" class="w-full bg-[#f5eeff] border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-[#4a40e0] outline-none text-sm" value="5" min="1" max="50">
                                </div>
                            </div>
                            <div>
                                <label class="block text-xs font-bold uppercase tracking-wider text-[#32294f]/60 mb-2 mt-4">Deadline (Optional)</label>
                                <input type="datetime-local" id="quizDeadline" class="w-full bg-[#f5eeff] border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-[#4a40e0] outline-none text-sm">
                            </div>
                        </div>
                        
                        <button id="generateBtn" onclick="generateAndShowMCQs('<%= course.id %>')" class="w-full bg-[#4a40e0] text-white font-bold py-3 rounded-xl hover:bg-[#3d30d4] transition-colors flex justify-center items-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">magic_button</span> Generate Questions
                        </button>
                        
                        <div id="aiResultArea" class="mt-6 pt-6 border-t border-[#e2d7ff] hidden">
                            <h3 class="font-bold text-sm text-[#4a40e0] mb-3 uppercase tracking-wider flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">task_alt</span> Preview</h3>
                            <div id="aiResultQuestions" class="bg-[#faf4ff] p-4 rounded-xl text-sm border border-[#e2d7ff] max-h-[250px] overflow-y-auto mb-4 space-y-4 shadow-inner">
                                <!-- Generated questions will appear here -->
                            </div>
                            <button id="saveQuizBtn" onclick="saveGeneratedQuiz('<%= course.id %>')" class="w-full bg-[#10b981] text-white font-bold py-3 rounded-xl hover:bg-[#059669] transition-colors flex justify-center items-center gap-2 shadow-lg shadow-[#10b981]/20">
                                <span class="material-symbols-outlined text-[18px]">save</span> Publish Quiz to Course
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Existing Quizzes -->
                <div class="space-y-4">
                    <h2 class="text-xl font-bold">Published Quizzes</h2>
                    
                    <% if (quizzes && quizzes.length > 0) { %>
                        <div class="space-y-3">
                            <% quizzes.forEach(q => { %>
                                <a href="/teacher/quiz/<%= q.id %>/scores" class="block bg-white rounded-2xl p-5 border border-[#e2d7ff] shadow-sm flex items-center justify-between hover:border-[#9795ff] transition-colors group">
                                    <div class="flex items-center gap-4 min-w-0">
                                        <div class="w-12 h-12 flex-shrink-0 rounded-xl bg-[#e6f4ea] text-[#137333] flex items-center justify-center group-hover:bg-[#d1e7dd] transition-colors">
                                            <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">assignment</span>
                                        </div>
                                        <div class="min-w-0">
                                            <h4 class="font-bold text-[#32294f] group-hover:text-[#4a40e0] transition-colors truncate"><%= q.title %></h4>
                                            <p class="text-[10px] uppercase font-bold text-[#32294f]/50 tracking-wider">AI Generated &bull; View Scores</p>
                                        </div>
                                    </div>
                                    <span class="material-symbols-outlined text-[#32294f]/30 group-hover:text-[#4a40e0]">chevron_right</span>
                                </a>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="bg-white rounded-3xl p-10 text-center border border-[#e2d7ff] border-dashed">
                            <div class="w-16 h-16 bg-[#faf4ff] text-[#4a40e0]/40 rounded-full flex items-center justify-center mx-auto mb-4">
                                <span class="material-symbols-outlined text-3xl">quiz</span>
                            </div>
                            <h3 class="font-bold text-lg mb-2">No Quizzes Yet</h3>
                            <p class="text-[#32294f]/60 text-sm">Use the AI generator to create your first assessment.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

    </main>

    <!-- Bottom Navigation -->
    

    <!-- MODALS -->
    <!-- Upload Material Modal -->
    <div id="uploadModal" class="fixed inset-0 bg-[#10062d]/40 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-3xl w-full max-w-md shadow-2xl overflow-hidden transform scale-95 opacity-0 transition-all duration-200" id="uploadModalContent">
            <div class="p-6 border-b border-[#e2d7ff] flex justify-between items-center bg-[#faf4ff]">
                <h3 class="font-bold text-xl">Upload Material</h3>
                <button onclick="closeUploadModal()" class="text-[#32294f]/40 hover:text-[#32294f]"><span class="material-symbols-outlined">close</span></button>
            </div>
            
            <form action="/teacher/course/<%= course.id %>/upload" method="POST" enctype="multipart/form-data" class="p-6">
                <div class="mb-5">
                    <label class="block text-sm font-bold mb-2">Material Title</label>
                    <input type="text" name="material_title" class="w-full bg-[#f5eeff] border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-[#4a40e0] outline-none" required placeholder="e.g. Chapter 1 Notes">
                </div>
                
                <!-- Inner Tabs -->
                <div class="flex space-x-2 bg-[#f5eeff] p-1 rounded-xl mb-5">
                    <button type="button" onclick="switchUploadType('pdf')" id="btn-type-pdf" class="flex-1 py-2 text-sm font-bold rounded-lg bg-white shadow-sm text-[#4a40e0] transition-colors">PDF File</button>
                    <button type="button" onclick="switchUploadType('video')" id="btn-type-video" class="flex-1 py-2 text-sm font-bold rounded-lg text-[#32294f]/60 hover:text-[#4a40e0] transition-colors">Video URL</button>
                </div>

                <div id="upload-pdf-section" class="mb-6">
                    <label class="block text-sm font-bold mb-2">Select PDF</label>
                    <input type="file" name="material" accept=".pdf" class="w-full text-sm text-[#32294f]/60 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-bold file:bg-[#e8deff] file:text-[#4a40e0] hover:file:bg-[#dcc9ff] transition-colors">
                </div>

                <div id="upload-video-section" class="mb-6 hidden">
                    <label class="block text-sm font-bold mb-2">YouTube / Vimeo URL</label>
                    <input type="url" name="video_url" class="w-full bg-[#f5eeff] border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-[#4a40e0] outline-none" placeholder="https://youtube.com/watch?v=...">
                </div>

                <button type="submit" class="w-full bg-[#4a40e0] text-white font-bold py-3 rounded-xl hover:bg-[#3d30d4] transition-colors flex justify-center items-center gap-2">
                    <span class="material-symbols-outlined">upload</span> Upload Material
                </button>
            </form>
        </div>
    </div>

    <!-- Edit Material Modal -->
    <div id="editModal" class="fixed inset-0 bg-[#10062d]/40 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-3xl w-full max-w-md shadow-2xl overflow-hidden transform scale-95 opacity-0 transition-all duration-200" id="editModalContent">
            <div class="p-6 border-b border-[#e2d7ff] flex justify-between items-center bg-[#faf4ff]">
                <h3 class="font-bold text-xl">Edit Title</h3>
                <button onclick="closeEditModal()" class="text-[#32294f]/40 hover:text-[#32294f]"><span class="material-symbols-outlined">close</span></button>
            </div>
            
            <form id="editMaterialForm" class="p-6">
                <div class="mb-6">
                    <label class="block text-sm font-bold mb-2">New Title</label>
                    <input type="text" id="edit_material_title" name="title" class="w-full bg-[#f5eeff] border-none rounded-xl px-4 py-3 focus:ring-2 focus:ring-[#4a40e0] outline-none" required>
                </div>
                
                <button type="submit" id="editUpdateBtn" class="w-full bg-[#4a40e0] text-white font-bold py-3 rounded-xl hover:bg-[#3d30d4] transition-colors flex justify-center items-center gap-2">
                    <span class="material-symbols-outlined">save</span> Update
                </button>
            </form>
        </div>
    </div>

    <script>
        function toggleProfileDropdown() {
            const d = document.getElementById('profileDropdown');
            d.classList.toggle('hidden');
        }

        // Close dropdown when clicking outside
        window.addEventListener('click', (e) => {
            const btn = document.getElementById('profileBtn');
            const d = document.getElementById('profileDropdown');
            if (btn && !btn.contains(e.target) && d && !d.contains(e.target)) {
                d.classList.add('hidden');
            }
        });

        // Main Tabs
        function switchTab(tab) {
            document.getElementById('tab-content-materials').classList.add('hidden');
            document.getElementById('tab-content-quizzes').classList.add('hidden');
            document.getElementById(`tab-content-${tab}`).classList.remove('hidden');

            const btnM = document.getElementById('tab-btn-materials');
            const btnQ = document.getElementById('tab-btn-quizzes');

            if(tab === 'materials') {
                btnM.classList.add('border-[#4a40e0]', 'text-[#4a40e0]');
                btnM.classList.remove('border-transparent', 'text-[#32294f]/60');
                btnQ.classList.remove('border-[#4a40e0]', 'text-[#4a40e0]');
                btnQ.classList.add('border-transparent', 'text-[#32294f]/60');
            } else {
                btnQ.classList.add('border-[#4a40e0]', 'text-[#4a40e0]');
                btnQ.classList.remove('border-transparent', 'text-[#32294f]/60');
                btnM.classList.remove('border-[#4a40e0]', 'text-[#4a40e0]');
                btnM.classList.add('border-transparent', 'text-[#32294f]/60');
            }
        }

        // Upload Modals & Inner Tabs
        function openUploadModal() {
            const m = document.getElementById('uploadModal');
            const c = document.getElementById('uploadModalContent');
            m.classList.remove('hidden');
            setTimeout(() => { c.classList.remove('scale-95', 'opacity-0'); }, 10);
        }
        function closeUploadModal() {
            const m = document.getElementById('uploadModal');
            const c = document.getElementById('uploadModalContent');
            c.classList.add('scale-95', 'opacity-0');
            setTimeout(() => { m.classList.add('hidden'); }, 200);
        }

        function switchUploadType(type) {
            const pdfSec = document.getElementById('upload-pdf-section');
            const vidSec = document.getElementById('upload-video-section');
            const btnPdf = document.getElementById('btn-type-pdf');
            const btnVid = document.getElementById('btn-type-video');

            if(type === 'pdf') {
                pdfSec.classList.remove('hidden'); vidSec.classList.add('hidden');
                btnPdf.classList.add('bg-white', 'shadow-sm', 'text-[#4a40e0]'); btnPdf.classList.remove('text-[#32294f]/60');
                btnVid.classList.remove('bg-white', 'shadow-sm', 'text-[#4a40e0]'); btnVid.classList.add('text-[#32294f]/60');
            } else {
                vidSec.classList.remove('hidden'); pdfSec.classList.add('hidden');
                btnVid.classList.add('bg-white', 'shadow-sm', 'text-[#4a40e0]'); btnVid.classList.remove('text-[#32294f]/60');
                btnPdf.classList.remove('bg-white', 'shadow-sm', 'text-[#4a40e0]'); btnPdf.classList.add('text-[#32294f]/60');
            }
        }

        // Edit Material Flow
        let currentEditMaterialId = null;
        let currentEditCourseId = null;

        function editMaterial(materialId, currentTitle) {
            currentEditMaterialId = materialId;
            currentEditCourseId = '<%= course.id %>';
            document.getElementById('edit_material_title').value = currentTitle;
            
            const m = document.getElementById('editModal');
            const c = document.getElementById('editModalContent');
            m.classList.remove('hidden');
            setTimeout(() => { c.classList.remove('scale-95', 'opacity-0'); }, 10);
        }
        function closeEditModal() {
            const m = document.getElementById('editModal');
            const c = document.getElementById('editModalContent');
            c.classList.add('scale-95', 'opacity-0');
            setTimeout(() => { m.classList.add('hidden'); }, 200);
        }

        document.getElementById('editMaterialForm').addEventListener('submit', async function(e) {
            e.preventDefault();
            const title = document.getElementById('edit_material_title').value;
            const btn = document.getElementById('editUpdateBtn');
            btn.innerHTML = '<span class="material-symbols-outlined animate-spin">refresh</span> Updating...';
            
            if (!title) return;

            try {
                const response = await fetch(`/teacher/course/${currentEditCourseId}/material/${currentEditMaterialId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title })
                });

                const data = await response.json();
                if (data.success) {
                    window.location.reload();
                } else {
                    alert('Failed to update material: ' + data.error);
                    btn.innerHTML = 'Update';
                }
            } catch (err) {
                alert('Error: ' + err.message);
                btn.innerHTML = 'Update';
            }
        });

        async function deleteMaterial(materialId, courseId) {
            if (!confirm('Are you sure you want to delete this material?')) return;
            try {
                const response = await fetch(`/teacher/course/${courseId}/material/${materialId}`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' }
                });
                const data = await response.json();
                if (data.success) window.location.reload();
                else alert('Failed to delete material: ' + data.error);
            } catch (err) { alert('Error: ' + err.message); }
        }

        // AI Quiz Generation Flow
        let currentGeneratedQuestions = null;

        async function generateAndShowMCQs(courseId) {
            const topic = document.getElementById('aiTopic').value;
            const title = document.getElementById('quizTitle').value;
            const count = document.getElementById('aiCount').value;
            const btn = document.getElementById('generateBtn');
            const resultArea = document.getElementById('aiResultArea');
            const questionsDiv = document.getElementById('aiResultQuestions');
            
            if(!topic || !title) return alert("Please provide both a Quiz Title and a Topic.");

            btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">refresh</span> Generating Magic...';
            btn.disabled = true;

            try {
                const response = await fetch('/ai/teacher/generate-mcq', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ topic, count })
                });
                
                const data = await response.json();
                if(data.success) {
                    currentGeneratedQuestions = data.questions;
                    let html = '';
                    let questionsArray = typeof data.questions === 'string' ? JSON.parse(data.questions) : data.questions;
                    
                    questionsArray.forEach((q, index) => {
                        html += `<div class="mb-3"><b class="block mb-1 text-[#32294f]">Q${index+1}: ${q.question}</b><ul class="space-y-1 ml-2">`;
                        q.options.forEach(opt => {
                            html += `<li class="flex items-center gap-2 text-[#32294f]/80">- ${opt} ${opt === q.answer ? '<span class="material-symbols-outlined text-[16px] text-[#10b981]">check_circle</span>' : ''}</li>`;
                        });
                        html += `</ul></div>`;
                    });
                    
                    questionsDiv.innerHTML = html;
                    resultArea.classList.remove('hidden');
                } else {
                    alert('Generation Failed: ' + data.error);
                }
            } catch (err) {
                alert('Error: ' + err.message);
            } finally {
                btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">magic_button</span> Generate Questions';
                btn.disabled = false;
            }
        }

        async function saveGeneratedQuiz(courseId) {
            const title = document.getElementById('quizTitle').value;
            const deadline = document.getElementById('quizDeadline').value;
            const btn = document.getElementById('saveQuizBtn');
            if(!currentGeneratedQuestions || !title) return;

            btn.innerHTML = '<span class="material-symbols-outlined animate-spin text-[18px]">refresh</span> Publishing...';
            btn.disabled = true;

            try {
                const questionsJson = typeof currentGeneratedQuestions === 'string' ? JSON.parse(currentGeneratedQuestions) : currentGeneratedQuestions;

                const response = await fetch(`/teacher/course/${courseId}/quiz/save`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title: title, questions_json: questionsJson, deadline: deadline || null })
                });
                
                const data = await response.json();
                if(data.success) window.location.reload();
                else {
                    alert('Failed to save quiz: ' + data.error);
                    btn.innerHTML = '<span class="material-symbols-outlined text-[18px]">save</span> Publish Quiz to Course';
                    btn.disabled = false;
                }
            } catch (err) {
                alert('Error: ' + err.message);
                btn.disabled = false;
            }
        }
    </script>
</body>
</html>
