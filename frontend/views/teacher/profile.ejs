<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Teacher Profile - EduConnectAI</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#4a40e0',
                        secondary: '#702ae1',
                        'primary-container': '#e8deff',
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@700;800&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
    <style>
        body { font-family: 'Inter', sans-serif; }
        .font-headline { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="bg-[#faf4ff] text-[#32294f] min-h-screen">
    <!-- Header -->
    <header class="w-full top-0 px-6 py-4 fixed bg-white/70 backdrop-blur-xl z-50 border-b border-[#e2d7ff]/30">
        <div class="flex justify-between items-center max-w-7xl mx-auto">
            <div class="flex items-center gap-4">
                <a href="/teacher/dashboard" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-[#f5eeff] transition-colors">
                    <span class="material-symbols-outlined text-primary">arrow_back</span>
                </a>
                <h1 class="text-xl font-bold font-headline text-primary">Teacher Profile</h1>
            </div>
        </div>
    </header>

    <main class="pt-32 px-6 pb-20 max-w-3xl mx-auto">
        <div class="bg-white rounded-[2.5rem] shadow-xl shadow-primary/5 overflow-hidden border border-[#e2d7ff]/30">
            <!-- Profile Header/Cover -->
            <div class="h-32 bg-gradient-to-r from-primary to-secondary opacity-20"></div>
            
            <div class="px-8 pb-10 -mt-16">
                <div class="flex flex-col items-center">
                    <!-- Avatar -->
                    <div class="relative group">
                        <div class="w-32 h-32 rounded-full border-4 border-white shadow-lg overflow-hidden bg-primary-container flex items-center justify-center">
                            <% if (user.profile_image) { %>
                                <img src="<%= user.profile_image %>" class="w-full h-full object-cover" alt="Profile">
                            <% } else { %>
                                <span class="text-4xl font-black text-white"><%= user.name.charAt(0).toUpperCase() %></span>
                            <% } %>
                        </div>
                        <label for="profile_image_input" class="absolute bottom-0 right-0 w-10 h-10 bg-primary text-white rounded-full border-4 border-white flex items-center justify-center cursor-pointer hover:scale-110 transition-transform shadow-md">
                            <span class="material-symbols-outlined text-[20px]">photo_camera</span>
                        </label>
                        <form id="imageUploadForm" action="/teacher/profile/upload-image" method="POST" enctype="multipart/form-data" class="hidden">
                            <input type="file" name="profile_image" id="profile_image_input" accept="image/*" onchange="this.form.submit()">
                        </form>
                    </div>

                    <div class="mt-6 text-center">
                        <h2 class="text-2xl font-black font-headline"><%= user.name %></h2>
                        <p class="text-sm font-bold text-[#5f557f] uppercase tracking-widest mt-1">Faculty Member</p>
                    </div>
                </div>

                <div class="mt-12 space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-[#5f557f] uppercase tracking-[0.2em] ml-2">Full Name</label>
                            <div class="bg-[#faf4ff] px-6 py-4 rounded-2xl border border-[#e2d7ff]/50 font-bold">
                                <%= user.name %>
                            </div>
                        </div>
                        <div class="space-y-2">
                            <label class="text-[10px] font-black text-[#5f557f] uppercase tracking-[0.2em] ml-2">Email Address</label>
                            <div class="bg-[#faf4ff] px-6 py-4 rounded-2xl border border-[#e2d7ff]/50 font-bold">
                                <%= user.email %>
                            </div>
                        </div>
                    </div>

                    <div class="pt-8 border-t border-[#e2d7ff]/30 space-y-4">
                        <h3 class="text-lg font-black font-headline mb-4">Account Management</h3>
                        <button onclick="openChangePasswordModal()" class="w-full py-4 rounded-2xl border-2 border-[#4a40e0]/10 text-[#4a40e0] font-bold hover:bg-[#4a40e0] hover:text-white transition-all flex items-center justify-center gap-3">
                            <span class="material-symbols-outlined">lock_reset</span>
                            Change Password
                        </button>
                        <a href="/auth/logout" class="w-full py-4 rounded-2xl bg-red-50 text-red-500 font-bold hover:bg-red-500 hover:text-white transition-all flex items-center justify-center gap-3">
                            <span class="material-symbols-outlined">logout</span>
                            Logout Account
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Change Password Modal -->
    <div id="passwordModal" class="fixed inset-0 bg-[#10062d]/40 backdrop-blur-sm z-[60] hidden flex items-center justify-center p-4">
        <div id="passwordModalContent" class="bg-white rounded-[2.5rem] w-full max-w-md shadow-2xl overflow-hidden transform scale-95 opacity-0 transition-all duration-200">
            <div class="p-8 border-b border-[#e2d7ff]/30 flex justify-between items-center bg-[#faf4ff]">
                <h3 class="font-black font-headline text-xl">Change Password</h3>
                <button onclick="closeChangePasswordModal()" class="text-[#32294f]/40 hover:text-[#32294f] transition-colors">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>
            
            <form id="changePasswordForm" class="p-8 space-y-6">
                <div class="space-y-2">
                    <label class="text-[10px] font-black text-[#5f557f] uppercase tracking-[0.2em] ml-2">Current Password</label>
                    <div class="relative group">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#32294f]/30 group-focus-within:text-primary transition-colors text-[20px]">lock</span>
                        <input type="password" id="currentPassword" required
                               class="w-full bg-[#faf4ff] border-2 border-transparent rounded-2xl pl-12 pr-12 py-4 focus:bg-white focus:border-primary/30 focus:ring-4 focus:ring-primary/5 outline-none transition-all font-bold">
                        <button type="button" onclick="togglePasswordVisibility('currentPassword', 'eye1')" class="absolute right-4 top-1/2 -translate-y-1/2 text-[#32294f]/30 hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-[20px]" id="eye1">visibility</span>
                        </button>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black text-[#5f557f] uppercase tracking-[0.2em] ml-2">New Password</label>
                    <div class="relative group">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#32294f]/30 group-focus-within:text-primary transition-colors text-[20px]">lock_reset</span>
                        <input type="password" id="newPassword" required
                               class="w-full bg-[#faf4ff] border-2 border-transparent rounded-2xl pl-12 pr-12 py-4 focus:bg-white focus:border-primary/30 focus:ring-4 focus:ring-primary/5 outline-none transition-all font-bold">
                        <button type="button" onclick="togglePasswordVisibility('newPassword', 'eye2')" class="absolute right-4 top-1/2 -translate-y-1/2 text-[#32294f]/30 hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-[20px]" id="eye2">visibility</span>
                        </button>
                    </div>
                </div>

                <div class="space-y-2">
                    <label class="text-[10px] font-black text-[#5f557f] uppercase tracking-[0.2em] ml-2">Confirm New Password</label>
                    <div class="relative group">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-[#32294f]/30 group-focus-within:text-primary transition-colors text-[20px]">verified_user</span>
                        <input type="password" id="confirmPassword" required
                               class="w-full bg-[#faf4ff] border-2 border-transparent rounded-2xl pl-12 pr-12 py-4 focus:bg-white focus:border-primary/30 focus:ring-4 focus:ring-primary/5 outline-none transition-all font-bold">
                        <button type="button" onclick="togglePasswordVisibility('confirmPassword', 'eye3')" class="absolute right-4 top-1/2 -translate-y-1/2 text-[#32294f]/30 hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-[20px]" id="eye3">visibility</span>
                        </button>
                    </div>
                </div>

                <button type="submit" id="submitBtn" class="w-full bg-primary text-white font-black font-headline py-5 rounded-2xl shadow-xl shadow-primary/20 hover:scale-[1.02] active:scale-[0.98] transition-all flex items-center justify-center gap-3 mt-4">
                    Update Password
                    <span class="material-symbols-outlined">check_circle</span>
                </button>
            </form>
        </div>
    </div>

    <!-- Sidebar/Nav Context (For Teacher Dashboard reference) -->
    <div class="fixed bottom-10 right-10">
        <a href="/teacher/dashboard" class="flex items-center gap-3 px-6 py-3 rounded-2xl bg-white shadow-xl border border-[#e2d7ff]/30 hover:scale-105 transition-all text-primary font-bold">
            <span class="material-symbols-outlined">dashboard</span>
            Back to Dashboard
        </a>
    </div>

    <script>
        function openChangePasswordModal() {
            const m = document.getElementById('passwordModal');
            const c = document.getElementById('passwordModalContent');
            m.classList.remove('hidden');
            setTimeout(() => {
                c.classList.remove('scale-95', 'opacity-0');
            }, 10);
        }

        function closeChangePasswordModal() {
            const m = document.getElementById('passwordModal');
            const c = document.getElementById('passwordModalContent');
            c.classList.add('scale-95', 'opacity-0');
            setTimeout(() => {
                m.classList.add('hidden');
            }, 200);
        }

        function togglePasswordVisibility(inputId, iconId) {
            const input = document.getElementById(inputId);
            const icon = document.getElementById(iconId);
            if (input.type === 'password') {
                input.type = 'text';
                icon.innerText = 'visibility_off';
            } else {
                input.type = 'password';
                icon.innerText = 'visibility';
            }
        }

        document.getElementById('changePasswordForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const currentPassword = document.getElementById('currentPassword').value;
            const newPassword = document.getElementById('newPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const btn = document.getElementById('submitBtn');

            if (newPassword !== confirmPassword) {
                alert('New passwords do not match');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="material-symbols-outlined animate-spin">refresh</span> Updating...';

            try {
                const res = await fetch('/teacher/profile/change-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ currentPassword, newPassword })
                });

                const data = await res.json();
                if (data.success) {
                    alert('Password updated successfully!');
                    closeChangePasswordModal();
                    document.getElementById('changePasswordForm').reset();
                } else {
                    alert(data.error || 'Failed to update password');
                }
            } catch (err) {
                alert('Error updating password');
            } finally {
                btn.disabled = false;
                btn.innerHTML = 'Update Password <span class="material-symbols-outlined">check_circle</span>';
            }
        });
    </script>
</body>
</html>
